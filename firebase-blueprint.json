{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Stone AIO platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "cloudComputerStatus": { "type": "string", "enum": ["inactive", "active"] },
        "agentRunsToday": { "type": "number" },
        "evolutionsToday": { "type": "number" },
        "lastResetDate": { "type": "string" },
        "totalRuns": { "type": "number" },
        "totalTokensUsed": { "type": "number" },
        "lastLoginAt": { "type": "timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Agent": {
      "title": "Agent",
      "description": "An AI agent created by a user.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["workflow", "autonomous", "voice", "browser", "content", "email"] },
        "role": { "type": "string" },
        "primaryMetric": { "type": "string" },
        "status": { "type": "string", "enum": ["idle", "running", "paused", "waiting_approval"] },
        "systemPrompt": { "type": "string" },
        "baseSystemPrompt": { "type": "string" },
        "currentStrategyId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "lastRunAt": { "type": "timestamp" },
        "totalRuns": { "type": "number" },
        "averageScore": { "type": "number" },
        "learningEnabled": { "type": "boolean" },
        "exploitRatio": { "type": "number" },
        "reflectionFrequency": { "type": "string" },
        "pinnedExampleIds": { "type": "array" },
        "extractedPatterns": { "type": "array" },
        "proposedSystemPrompt": { "type": "string" },
        "suggestExperiment": { "type": "boolean" },
        "evolutionCount": { "type": "number" },
        "lastEvolutionAt": { "type": "timestamp" },
        "alerts": { "type": "array" }
      },
      "required": ["agentId", "name", "type"]
    },
    "Strategy": {
      "title": "Strategy",
      "description": "A strategy used by an agent.",
      "type": "object",
      "properties": {
        "strategyId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "configurationSnapshot": { "type": "string" },
        "runCount": { "type": "number" },
        "totalScore": { "type": "number" },
        "averageScore": { "type": "number" },
        "confidenceInterval": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "testing", "archived"] },
        "source": { "type": "string", "enum": ["personal", "community", "experiment"] },
        "createdAt": { "type": "timestamp" },
        "lastUsedAt": { "type": "timestamp" }
      },
      "required": ["strategyId", "name"]
    },
    "Run": {
      "title": "Run",
      "description": "An execution run of an agent.",
      "type": "object",
      "properties": {
        "runId": { "type": "string" },
        "agentId": { "type": "string" },
        "strategyId": { "type": "string" },
        "taskDescription": { "type": "string" },
        "outputSnapshot": { "type": "string" },
        "primaryScore": { "type": "number" },
        "secondaryScores": { "type": "object" },
        "humanRating": { "type": "number" },
        "humanNote": { "type": "string" },
        "savedToLibrary": { "type": "boolean" },
        "durationMs": { "type": "number" },
        "tokenCount": { "type": "number" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["runId", "agentId"]
    },
    "Reflection": {
      "title": "Reflection",
      "description": "A reflection generated by an agent.",
      "type": "object",
      "properties": {
        "reflectionId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "performanceSummary": { "type": "string" },
        "proposedChanges": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "appliedAt": { "type": "timestamp" }
      },
      "required": ["reflectionId"]
    },
    "Experiment": {
      "title": "Experiment",
      "description": "An A/B test experiment for an agent.",
      "type": "object",
      "properties": {
        "experimentId": { "type": "string" },
        "agentId": { "type": "string" },
        "agentName": { "type": "string" },
        "name": { "type": "string" },
        "hypothesis": { "type": "string" },
        "variantA": { "type": "object" },
        "variantB": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "completed", "paused"] },
        "targetRunsPerVariant": { "type": "number" },
        "currentRunsA": { "type": "number" },
        "currentRunsB": { "type": "number" },
        "scoresA": { "type": "array" },
        "scoresB": { "type": "array" },
        "winnerId": { "type": "string" },
        "tStat": { "type": "number" },
        "createdAt": { "type": "timestamp" },
        "completedAt": { "type": "timestamp" }
      },
      "required": ["experimentId", "agentId"]
    },
    "TeamMemory": {
      "title": "Team Memory",
      "description": "A shared insight across agents.",
      "type": "object",
      "properties": {
        "memoryId": { "type": "string" },
        "sourceAgentId": { "type": "string" },
        "sourceAgentName": { "type": "string" },
        "insight": { "type": "string" },
        "category": { "type": "string" },
        "supportingScore": { "type": "number" },
        "applicableAgentTypes": { "type": "array" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["memoryId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for the user.",
      "type": "object",
      "properties": {
        "notifId": { "type": "string" },
        "type": { "type": "string" },
        "agentId": { "type": "string" },
        "agentName": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "actionType": { "type": "string" },
        "actionPayload": { "type": "object" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["notifId"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/users/{uid}/agents/{agentId}": {
      "schema": { "$ref": "Agent" },
      "description": "User's agents"
    },
    "/users/{uid}/agents/{agentId}/strategies/{strategyId}": {
      "schema": { "$ref": "Strategy" },
      "description": "Agent's strategies"
    },
    "/users/{uid}/agents/{agentId}/runs/{runId}": {
      "schema": { "$ref": "Run" },
      "description": "Agent's runs"
    },
    "/users/{uid}/agents/{agentId}/reflections/{reflectionId}": {
      "schema": { "$ref": "Reflection" },
      "description": "Agent's reflections"
    },
    "/users/{uid}/experiments/{experimentId}": {
      "schema": { "$ref": "Experiment" },
      "description": "User's experiments"
    },
    "/users/{uid}/teamMemory/{memoryId}": {
      "schema": { "$ref": "TeamMemory" },
      "description": "User's team memories"
    },
    "/users/{uid}/notifications/{notifId}": {
      "schema": { "$ref": "Notification" },
      "description": "User's notifications"
    }
  }
}
